#define V_MELEE_UPPERCUT 7
#define V_MELEE_SPINKICK 8
#define V_MELEE_BACKKICK 9
#define V_MELEE_PUNCH_RIGHT2 10

entityDef weapon_karate
{
"editor_color"		".3 .3 1"
"editor_mins"		"-16 -16 -16"
"editor_maxs"		"16 16 16"
